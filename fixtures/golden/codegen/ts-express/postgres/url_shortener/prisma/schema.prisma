generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model UrlMapping {

  id Int @id @default(autoincrement())

  code String @db.Text

  url String @db.Text

  createdAt DateTime @map("created_at") @db.Timestamptz()

  clickCount Int @map("click_count") @db.Integer


  @@map("url_mappings")
}


