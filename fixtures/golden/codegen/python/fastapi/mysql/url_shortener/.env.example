# Database connection string (async SQLAlchemy + aiomysql)
DATABASE_URL=mysql+aiomysql://url_shortener:url_shortener@db:3306/url_shortener

# Base URL the service is reachable at (used for constructing absolute URLs)
BASE_URL=http://localhost:8000

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# Optional bearer credential for the /admin surface; leave unset to disable it (404)
ADMIN_TOKEN=

# ─── Required for staging / production (no defaults) ────────────────────────
# docker-compose.prod.yml fails fast (`${KEY:?…}`) if any of these is unset.
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=
# MYSQL_ROOT_PASSWORD=
