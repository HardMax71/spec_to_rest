DATABASE_URL=postgresql://url_shortener:url_shortener@db:5432/url_shortener?schema=public
BASE_URL=http://localhost:8080
PORT=8080
LOG_LEVEL=info
ADMIN_TOKEN=

# ─── Required for staging / production (no defaults) ────────────────────────
# docker-compose.prod.yml fails fast (`${KEY:?…}`) if any of these is unset.
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=
