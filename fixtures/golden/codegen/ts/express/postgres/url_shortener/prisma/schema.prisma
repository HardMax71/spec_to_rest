generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UrlMapping {
  id BigInt @id @default(autoincrement()) @db.BigInt
  code String @db.Text
  url String @db.Text
  created_at DateTime @db.Timestamptz()
  click_count Int @db.Integer

  @@map("url_mappings")
}

