DATABASE_URL=mysql://url_shortener:url_shortener@db:3306/url_shortener
BASE_URL=http://localhost:8080
PORT=8080
LOG_LEVEL=info
ADMIN_TOKEN=

# ─── Required for staging / production (no defaults) ────────────────────────
# docker-compose.prod.yml fails fast (`${KEY:?…}`) if any of these is unset.
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=
# MYSQL_ROOT_PASSWORD=
