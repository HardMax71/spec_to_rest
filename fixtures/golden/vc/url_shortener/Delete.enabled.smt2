(set-logic ALL)
(set-option :produce-models true)
(set-option :timeout 30000)
;; sorts
(declare-sort UrlMapping 0)
;; funcs
(declare-fun input_Delete_code () String)
(declare-fun isValidURI_String (String) Bool)
(declare-fun len_String (String) Int)
(declare-fun matches_0_String (String) Bool)
(declare-fun metadata_dom (String) Bool)
(declare-fun metadata_map (String) UrlMapping)
(declare-fun state_base_url () String)
(declare-fun store_dom (String) Bool)
(declare-fun store_map (String) String)
(declare-fun UrlMapping_click_count (UrlMapping) Int)
(declare-fun UrlMapping_code (UrlMapping) String)
(declare-fun UrlMapping_created_at (UrlMapping) Int)
(declare-fun UrlMapping_url (UrlMapping) String)
;; assertions
(assert (forall ((k_store_key String)) (! (=> (store_dom k_store_key) (and (>= (len_String k_store_key) 6) (str.in_re k_store_key (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9")))))) :pattern ((store_dom k_store_key)))))
(assert (forall ((k_store String)) (! (=> (store_dom k_store) (and (< 0 (len_String (store_map k_store))) (isValidURI_String (store_map k_store)))) :pattern ((store_dom k_store)))))
(assert (forall ((k_metadata_key String)) (! (=> (metadata_dom k_metadata_key) (and (>= (len_String k_metadata_key) 6) (str.in_re k_metadata_key (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9")))))) :pattern ((metadata_dom k_metadata_key)))))
(assert (isValidURI_String state_base_url))
(assert (forall ((self_UrlMapping UrlMapping)) (! (and (>= (len_String (UrlMapping_code self_UrlMapping)) 6) (str.in_re (UrlMapping_code self_UrlMapping) (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9"))))) :pattern ((UrlMapping_code self_UrlMapping)))))
(assert (forall ((self_UrlMapping UrlMapping)) (! (and (< 0 (len_String (UrlMapping_url self_UrlMapping))) (isValidURI_String (UrlMapping_url self_UrlMapping))) :pattern ((UrlMapping_url self_UrlMapping)))))
(assert (forall ((self_UrlMapping UrlMapping)) (! (>= (UrlMapping_click_count self_UrlMapping) 0) :pattern ((UrlMapping_click_count self_UrlMapping)))))
(assert (forall ((self_UrlMapping UrlMapping)) (! (isValidURI_String (UrlMapping_url self_UrlMapping)) :pattern ((UrlMapping_url self_UrlMapping)))))
(assert (forall ((c String)) (! (=> (store_dom c) (matches_0_String (store_map c))) :pattern ((store_dom c)))))
(assert (and (forall ((x String)) (! (=> (store_dom x) (metadata_dom x)) :pattern ((store_dom x)))) (forall ((x String)) (! (=> (metadata_dom x) (store_dom x)) :pattern ((metadata_dom x))))))
(assert (forall ((c String)) (! (=> (metadata_dom c) (>= (UrlMapping_click_count (metadata_map c)) 0)) :pattern ((metadata_dom c)))))
(assert (and (>= (len_String input_Delete_code) 6) (str.in_re input_Delete_code (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9"))))))
(assert (store_dom input_Delete_code))
(check-sat)
