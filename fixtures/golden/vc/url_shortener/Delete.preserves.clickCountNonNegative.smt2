(set-logic ALL)
(set-option :produce-models true)
(set-option :timeout 30000)
;; sorts
(declare-sort BaseURL 0)
(declare-sort DateTime 0)
(declare-sort LongURL 0)
(declare-sort ShortCode 0)
(declare-sort UrlMapping 0)
;; funcs
(declare-fun card_store () Int)
(declare-fun card_store_post () Int)
(declare-fun input_Delete_code () ShortCode)
(declare-fun isValidURI_BaseURL (BaseURL) Bool)
(declare-fun isValidURI_LongURL (LongURL) Bool)
(declare-fun len_LongURL (LongURL) Int)
(declare-fun len_ShortCode (ShortCode) Int)
(declare-fun matches_0_ShortCode (ShortCode) Bool)
(declare-fun metadata_dom (ShortCode) Bool)
(declare-fun metadata_dom_post (ShortCode) Bool)
(declare-fun metadata_map (ShortCode) UrlMapping)
(declare-fun metadata_map_post (ShortCode) UrlMapping)
(declare-fun state_base_url () BaseURL)
(declare-fun state_base_url_post () BaseURL)
(declare-fun store_dom (ShortCode) Bool)
(declare-fun store_dom_post (ShortCode) Bool)
(declare-fun store_map (ShortCode) LongURL)
(declare-fun store_map_post (ShortCode) LongURL)
(declare-fun UrlMapping_click_count (UrlMapping) Int)
(declare-fun UrlMapping_code (UrlMapping) ShortCode)
(declare-fun UrlMapping_created_at (UrlMapping) DateTime)
(declare-fun UrlMapping_url (UrlMapping) LongURL)
;; assertions
(assert (forall ((self_ShortCode ShortCode)) (and (and (>= (len_ShortCode self_ShortCode) 6) (<= (len_ShortCode self_ShortCode) 10)) (matches_0_ShortCode self_ShortCode))))
(assert (forall ((self_LongURL LongURL)) (and (> (len_LongURL self_LongURL) 0) (isValidURI_LongURL self_LongURL))))
(assert (forall ((self_BaseURL BaseURL)) (isValidURI_BaseURL self_BaseURL)))
(assert (forall ((self_UrlMapping UrlMapping)) (>= (UrlMapping_click_count self_UrlMapping) 0)))
(assert (forall ((self_UrlMapping UrlMapping)) (isValidURI_LongURL (UrlMapping_url self_UrlMapping))))
(assert (forall ((c ShortCode)) (=> (store_dom c) (isValidURI_LongURL (store_map c)))))
(assert (forall ((k_domeq_store_dom_metadata_dom ShortCode)) (and (=> (store_dom k_domeq_store_dom_metadata_dom) (metadata_dom k_domeq_store_dom_metadata_dom)) (=> (metadata_dom k_domeq_store_dom_metadata_dom) (store_dom k_domeq_store_dom_metadata_dom)))))
(assert (forall ((c ShortCode)) (=> (metadata_dom c) (>= (UrlMapping_click_count (metadata_map c)) 0))))
(assert (store_dom input_Delete_code))
(assert (not (store_dom_post input_Delete_code)))
(assert (not (metadata_dom_post input_Delete_code)))
(assert (>= card_store_post 0))
(assert (>= card_store 0))
(assert (= card_store_post (- card_store 1)))
(assert (forall ((k_pf_store ShortCode)) (and (=> (and (not (= k_pf_store input_Delete_code)) (store_dom k_pf_store)) (store_dom_post k_pf_store)) (=> (and (not (= k_pf_store input_Delete_code)) (not (store_dom k_pf_store))) (not (store_dom_post k_pf_store))) (=> (= k_pf_store input_Delete_code) (not (store_dom_post k_pf_store))))))
(assert (forall ((k_pf_store ShortCode)) (=> (and (store_dom k_pf_store) (not (= k_pf_store input_Delete_code))) (= (store_map_post k_pf_store) (store_map k_pf_store)))))
(assert (forall ((k_pf_metadata ShortCode)) (and (=> (and (not (= k_pf_metadata input_Delete_code)) (metadata_dom k_pf_metadata)) (metadata_dom_post k_pf_metadata)) (=> (and (not (= k_pf_metadata input_Delete_code)) (not (metadata_dom k_pf_metadata))) (not (metadata_dom_post k_pf_metadata))) (=> (= k_pf_metadata input_Delete_code) (not (metadata_dom_post k_pf_metadata))))))
(assert (forall ((k_pf_metadata ShortCode)) (=> (and (metadata_dom k_pf_metadata) (not (= k_pf_metadata input_Delete_code))) (= (metadata_map_post k_pf_metadata) (metadata_map k_pf_metadata)))))
(assert (= state_base_url_post state_base_url))
(assert (not (forall ((c ShortCode)) (=> (metadata_dom_post c) (>= (UrlMapping_click_count (metadata_map_post c)) 0)))))
(check-sat)
