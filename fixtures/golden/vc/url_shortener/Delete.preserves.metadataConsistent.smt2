(set-logic ALL)
(set-option :produce-models true)
(set-option :timeout 30000)
;; sorts
(declare-sort UrlMapping 0)
;; funcs
(declare-fun card_store () Int)
(declare-fun card_store_post () Int)
(declare-fun input_Delete_code () String)
(declare-fun isValidURI_String (String) Bool)
(declare-fun len_String (String) Int)
(declare-fun matches_0_String (String) Bool)
(declare-fun metadata_dom (String) Bool)
(declare-fun metadata_dom_post (String) Bool)
(declare-fun metadata_map (String) UrlMapping)
(declare-fun metadata_map_post (String) UrlMapping)
(declare-fun state_base_url () String)
(declare-fun state_base_url_post () String)
(declare-fun store_dom (String) Bool)
(declare-fun store_dom_post (String) Bool)
(declare-fun store_map (String) String)
(declare-fun store_map_post (String) String)
(declare-fun UrlMapping_click_count (UrlMapping) Int)
(declare-fun UrlMapping_code (UrlMapping) String)
(declare-fun UrlMapping_created_at (UrlMapping) Int)
(declare-fun UrlMapping_url (UrlMapping) String)
;; assertions
(assert (forall ((k_store_key String)) (! (=> (store_dom k_store_key) (and (>= (len_String k_store_key) 6) (str.in_re k_store_key (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9")))))) :pattern ((store_dom k_store_key)))))
(assert (forall ((k_store String)) (! (=> (store_dom k_store) (and (< 0 (len_String (store_map k_store))) (isValidURI_String (store_map k_store)))) :pattern ((store_dom k_store)))))
(assert (forall ((k_metadata_key String)) (! (=> (metadata_dom k_metadata_key) (and (>= (len_String k_metadata_key) 6) (str.in_re k_metadata_key (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9")))))) :pattern ((metadata_dom k_metadata_key)))))
(assert (isValidURI_String state_base_url))
(assert (forall ((self_UrlMapping UrlMapping)) (! (and (>= (len_String (UrlMapping_code self_UrlMapping)) 6) (str.in_re (UrlMapping_code self_UrlMapping) (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9"))))) :pattern ((UrlMapping_code self_UrlMapping)))))
(assert (forall ((self_UrlMapping UrlMapping)) (! (and (< 0 (len_String (UrlMapping_url self_UrlMapping))) (isValidURI_String (UrlMapping_url self_UrlMapping))) :pattern ((UrlMapping_url self_UrlMapping)))))
(assert (forall ((self_UrlMapping UrlMapping)) (! (>= (UrlMapping_click_count self_UrlMapping) 0) :pattern ((UrlMapping_click_count self_UrlMapping)))))
(assert (forall ((self_UrlMapping UrlMapping)) (! (isValidURI_String (UrlMapping_url self_UrlMapping)) :pattern ((UrlMapping_url self_UrlMapping)))))
(assert (forall ((k_store_key_post String)) (! (=> (store_dom_post k_store_key_post) (and (>= (len_String k_store_key_post) 6) (str.in_re k_store_key_post (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9")))))) :pattern ((store_dom_post k_store_key_post)))))
(assert (forall ((k_store_post String)) (! (=> (store_dom_post k_store_post) (and (< 0 (len_String (store_map_post k_store_post))) (isValidURI_String (store_map_post k_store_post)))) :pattern ((store_dom_post k_store_post)))))
(assert (forall ((k_metadata_key_post String)) (! (=> (metadata_dom_post k_metadata_key_post) (and (>= (len_String k_metadata_key_post) 6) (str.in_re k_metadata_key_post (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9")))))) :pattern ((metadata_dom_post k_metadata_key_post)))))
(assert (isValidURI_String state_base_url_post))
(assert (and (>= (len_String input_Delete_code) 6) (str.in_re input_Delete_code (re.+ (re.union (re.range "a" "z") (re.range "A" "Z") (re.range "0" "9"))))))
(assert (forall ((c String)) (! (=> (store_dom c) (matches_0_String (store_map c))) :pattern ((store_dom c)))))
(assert (and (forall ((x String)) (! (=> (store_dom x) (metadata_dom x)) :pattern ((store_dom x)))) (forall ((x String)) (! (=> (metadata_dom x) (store_dom x)) :pattern ((metadata_dom x))))))
(assert (forall ((c String)) (! (=> (metadata_dom c) (>= (UrlMapping_click_count (metadata_map c)) 0)) :pattern ((metadata_dom c)))))
(assert (store_dom input_Delete_code))
(assert (not (store_dom_post input_Delete_code)))
(assert (not (metadata_dom_post input_Delete_code)))
(assert (>= card_store_post 0))
(assert (>= card_store 0))
(assert (= card_store_post (- card_store 1)))
(assert (forall ((k_pf_store String)) (! (and (=> (and (not (= k_pf_store input_Delete_code)) (store_dom k_pf_store)) (store_dom_post k_pf_store)) (=> (and (not (= k_pf_store input_Delete_code)) (not (store_dom k_pf_store))) (not (store_dom_post k_pf_store))) (=> (= k_pf_store input_Delete_code) (not (store_dom_post k_pf_store)))) :pattern ((store_dom k_pf_store)) :pattern ((store_dom_post k_pf_store)))))
(assert (forall ((k_pf_store String)) (! (=> (and (store_dom k_pf_store) (not (= k_pf_store input_Delete_code))) (= (store_map_post k_pf_store) (store_map k_pf_store))) :pattern ((store_dom k_pf_store)))))
(assert (forall ((k_pf_metadata String)) (! (and (=> (and (not (= k_pf_metadata input_Delete_code)) (metadata_dom k_pf_metadata)) (metadata_dom_post k_pf_metadata)) (=> (and (not (= k_pf_metadata input_Delete_code)) (not (metadata_dom k_pf_metadata))) (not (metadata_dom_post k_pf_metadata))) (=> (= k_pf_metadata input_Delete_code) (not (metadata_dom_post k_pf_metadata)))) :pattern ((metadata_dom k_pf_metadata)) :pattern ((metadata_dom_post k_pf_metadata)))))
(assert (forall ((k_pf_metadata String)) (! (=> (and (metadata_dom k_pf_metadata) (not (= k_pf_metadata input_Delete_code))) (= (metadata_map_post k_pf_metadata) (metadata_map k_pf_metadata))) :pattern ((metadata_dom k_pf_metadata)))))
(assert (= state_base_url_post state_base_url))
(assert (not (and (forall ((x String)) (! (=> (store_dom_post x) (metadata_dom_post x)) :pattern ((store_dom_post x)))) (forall ((x String)) (! (=> (metadata_dom_post x) (store_dom_post x)) :pattern ((metadata_dom_post x)))))))
(check-sat)
