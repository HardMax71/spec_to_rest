{
  "name": "spec_to_rest",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Converts description of a service in DSL to REST API.",
  "bin": {
    "spec-to-rest": "./dist/cli.js"
  },
  "scripts": {
    "generate": "antlr-ng -Dlanguage=TypeScript -v -o src/parser/generated src/parser/Spec.g4",
    "build": "npm run generate && tsc",
    "test": "npm run generate && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "cli": "node --import tsx/esm src/cli.ts",
    "fmt": "prettier --write \"**/*.md\"",
    "fmt:check": "prettier --check \"**/*.md\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HardMax71/spec_to_rest.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/HardMax71/spec_to_rest/issues"
  },
  "homepage": "https://github.com/HardMax71/spec_to_rest#readme",
  "imports": {
    "#parser/*.js": "./src/parser/*.js",
    "#ir/*.js": "./src/ir/*.js",
    "#cli/*.js": "./src/cli/*.js",
    "#convention/*.js": "./src/convention/*.js"
  },
  "dependencies": {
    "antlr4ng": "^3.0.16",
    "commander": "^14.0.3",
    "consola": "^3.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "antlr-ng": "^1.0.10",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.0"
  }
}
