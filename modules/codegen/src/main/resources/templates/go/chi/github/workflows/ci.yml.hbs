name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  test:
    runs-on: ubuntu-latest
{{#if db.hasDbService}}    services:
      db:
        image: {{db.dbImage}}
        env:
{{#each db.composeEnv}}          {{this.key}}: {{this.value}}
{{/each}}        ports:
          - "{{db.dbPort}}:{{db.dbPort}}"
        options: >-
          --health-cmd "{{db.dbHealthCmd}}" --health-interval 5s --health-timeout 3s --health-retries 10
{{/if}}    env:
      DATABASE_URL: {{db.appDsn}}
      BASE_URL: http://localhost:8080
    steps:
      - uses: actions/checkout@{{pins.checkout}}
        with:
          persist-credentials: false
      - uses: actions/setup-go@{{pins.setupGo}}
        with:
          go-version: "1.22"
      - run: go mod tidy
{{#if hasDafny}}      - run: go vet $(go list ./... | grep -v '/internal/dafnykernel')
{{else}}      - run: go vet ./...
{{/if}}      - run: go test ./...

  security:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@{{pins.checkout}}
        with:
          persist-credentials: false
      - uses: actions/setup-go@{{pins.setupGo}}
        with:
          go-version: "1.22"
      - name: Audit dependencies (govulncheck)
        run: go run golang.org/x/vuln/cmd/govulncheck@v1.3.0 ./...
      - uses: astral-sh/setup-uv@{{pins.setupUv}}
      - name: Audit workflow files (zizmor)
        run: uvx zizmor=={{pins.zizmor}} .github/workflows/
