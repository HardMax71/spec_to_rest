services:
{{#if db.hasDbService}}
  db:
    image: {{db.dbImage}}
    environment:
{{#each db.composeEnv}}
      {{this.key}}: {{this.value}}
{{/each}}
    volumes:
      - db_data:{{db.dbVolumePath}}
    healthcheck:
      test: ["CMD-SHELL", "{{db.dbHealthCmd}}"]
      interval: 5s
      timeout: 3s
      retries: 10

{{/if}}
  migrations:
    build: .
    command: ["alembic", "upgrade", "head"]
    env_file: .env
{{#if db.hasDbService}}
    depends_on:
      db:
        condition: service_healthy
{{else}}
    volumes:
      - db_data:/data
{{/if}}

  app:
    build: .
    ports:
      - "8000:8000"
    env_file: .env
    environment:
      ENABLE_TEST_ADMIN: ${ENABLE_TEST_ADMIN:-}
{{#if db.hasDbService}}
    depends_on:
      db:
        condition: service_healthy
      migrations:
        condition: service_completed_successfully
{{else}}
    depends_on:
      migrations:
        condition: service_completed_successfully
    volumes:
      - db_data:/data
{{/if}}

volumes:
  db_data:
