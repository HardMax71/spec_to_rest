import json
import logging

import pytest
import structlog

from app.redaction import (
    configure_logging,
    is_sensitive,
    redact_sensitive,
)


@pytest.fixture(scope="session", autouse=True)
def _admin_endpoint_available():
    """Override the conftest fixture; redaction tests don't need a service."""
    yield


def test_is_sensitive_matches_exact_and_suffix():
    assert is_sensitive("password")
    assert is_sensitive("api_key")
    assert is_sensitive("session_token")
    assert is_sensitive("user_password")
    assert not is_sensitive("email")
    assert not is_sensitive("display_name")


def test_processor_redacts_top_level_sensitive_keys():
    out = redact_sensitive(None, "info", {"event": "login", "password": "hunter2"})
    assert out == {"event": "login", "password": "***REDACTED***"}


def test_processor_recurses_into_nested_dicts():
    out = redact_sensitive(
        None,
        "info",
        {"event": "request", "body": {"email": "a@b.com", "password": "hunter2"}},
    )
    assert out == {
        "event": "request",
        "body": {"email": "a@b.com", "password": "***REDACTED***"},
    }


def test_processor_pure_function_does_not_mask_non_sensitive():
    inp = {"email": "a@b.com", "user_id": 42}
    out = redact_sensitive(None, "info", inp)
    assert out == inp


def test_configure_logging_emits_redacted_json(capsys):
    configure_logging(level=logging.INFO, json=True)
    log = structlog.get_logger("redaction.smoke")
    log.info("login", email="a@b.com", password="hunter2")
    captured = capsys.readouterr()
    line = captured.err or captured.out
    assert line, "no log output captured"
    payload = json.loads(line.splitlines()[-1])
    assert payload["event"] == "login"
    assert payload["password"] == "***REDACTED***"
    assert payload["email"] == "a@b.com"
