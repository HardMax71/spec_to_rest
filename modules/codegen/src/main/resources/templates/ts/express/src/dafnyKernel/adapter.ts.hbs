import { randomInt } from 'node:crypto';
import BigNumber from 'bignumber.js';
// @ts-expect-error generated Dafny kernel ships without type declarations
import kernel from './kernel.cjs';

interface DafnySeq {
  toVerbatimString(asLiteral: boolean): string;
}
interface DafnyInt {
  toNumber(): number;
}

export const companion = kernel._module.__default as Record<
  string,
  (...args: unknown[]) => unknown
>;

export const makeState = (): unknown => new kernel._module.ServiceState();

// The generated state bridge builds relation maps and entity values through
// these; everything else goes through the typed converters below.
export const dafnyModule = kernel._module as Record<
  string,
  { [ctor: string]: (...args: unknown[]) => unknown }
>;

export const emptyDafnyMap = (): unknown => kernel._dafny.Map.Empty;

export const stringToDafny = (s: string): unknown =>
  kernel._dafny.Seq.UnicodeFromString(s);

export const stringFromDafny = (s: unknown): string =>
  (s as DafnySeq).toVerbatimString(false);

export const intToDafny = (n: number | bigint): unknown =>
  new BigNumber(typeof n === 'bigint' ? n.toString() : n);

export const intFromDafny = (n: unknown): number => (n as DafnyInt).toNumber();

// Lossless decimal rendering of a Dafny integer: toNumber() rounds past
// 2^53, so identity keys stringify straight from the BigNumber.
export const intKeyFromDafny = (n: unknown): string =>
  (n as DafnyInt & { toFixed(dp: number): string }).toFixed(0);

interface DafnyOption {
  is_Some: boolean;
  value: unknown;
}

const optionCompanion = dafnyModule['Option'] as unknown as {
  create_Some(value: unknown): unknown;
  create_None(): unknown;
};

export const someOrNone = (value: unknown, conv: (v: unknown) => unknown): unknown =>
  value === null || value === undefined
    ? optionCompanion.create_None()
    : optionCompanion.create_Some(conv(value));

export const valueOrNull = (opt: unknown, conv: (v: unknown) => unknown): unknown => {
  const o = opt as DafnyOption;
  return o.is_Some ? conv(o.value) : null;
};

import { InvalidInputError } from '../middleware/error.js';

// Dafny's js backend doubles underscores in constructor and member names.
const dafnyCtorName = (member: string): string => member.replace(/_/g, '__');

export const enumToDafny = (typeName: string, value: string): unknown => {
  const companion = dafnyModule[typeName] as Record<string, () => unknown>;
  const ctor = companion[`create_${dafnyCtorName(value)}`];
  if (typeof ctor !== 'function') {
    throw new InvalidInputError(`invalid ${typeName} value`);
  }
  return ctor.call(companion);
};

// Query values arrive as strings; the kernel boundary parses int-shaped
// ones here so garbage 422s through the shared error mapping.
export const intFromQueryString = (v: unknown): number => {
  // Number('') is 0, so the empty string must reject explicitly.
  const s = v as string;
  const n = s === '' ? Number.NaN : Number(s);
  if (!Number.isSafeInteger(n)) {
    throw new InvalidInputError('invalid integer value');
  }
  return n;
};

export const enumFromDafny = (typeName: string, values: string[], v: unknown): string => {
  const rec = v as Record<string, boolean>;
  for (const member of values) {
    if (rec[`is_${dafnyCtorName(member)}`]) return member;
  }
  throw new InvalidInputError(`invalid ${typeName} value`);
};

export const dafnySetOf = (values: unknown[]): unknown => {
  // Chunked union: spreading every element into one variadic call hits
  // engine argument limits on large hydrations.
  const S = kernel._dafny.Set as {
    fromElements(...xs: unknown[]): { Union(other: unknown): unknown };
  };
  let out: unknown = S.fromElements();
  for (let i = 0; i < values.length; i += 512) {
    out = (out as { Union(other: unknown): unknown }).Union(
      S.fromElements(...values.slice(i, i + 512)),
    );
  }
  return out;
};

export const dafnyCollToArray = (coll: unknown): unknown[] => {
  const out: unknown[] = [];
  const iterable = coll as Iterable<unknown>;
  for (const v of iterable) {
    out.push(v);
  }
  return out;
};

export const dafnySeqOf = (values: unknown[]): unknown => {
  // Chunked concatenation: spreading every element into one variadic call
  // hits engine argument limits on large hydrations.
  const S = kernel._dafny.Seq as {
    of(...xs: unknown[]): unknown;
    Concat(a: unknown, b: unknown): unknown;
  };
  let out = S.of();
  for (let i = 0; i < values.length; i += 512) {
    out = S.Concat(out, S.of(...values.slice(i, i + 512)));
  }
  return out;
};

// Fresh secrets come from the CSPRNG, never from the verified (hence
// deterministic) kernel; the compiled Requires twin validates each sample
// against live state before the kernel accepts it.
export const sampleCandidate = (length: number, charset: string): string => {
  // Array.from splits by code point, so a charset with non-BMP characters
  // cannot yield broken surrogate halves.
  const chars = Array.from(charset);
  let out = '';
  for (let i = 0; i < length; i += 1) {
    out += chars[randomInt(chars.length)];
  }
  return out;
};
