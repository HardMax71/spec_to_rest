generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "{{db.provider}}"
  url      = env("DATABASE_URL")
}

{{#each entities}}
model {{entity.modelClassName}} {
{{#each fields}}
  {{this.tsField}} {{this.prismaType}}{{#if this.nullable}}?{{/if}}{{#if this.prismaAttrs}} {{this.prismaAttrs}}{{/if}}
{{/each}}

  @@map("{{entity.tableName}}")
}

{{/each}}
