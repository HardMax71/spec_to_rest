{
  "name": "{{packageName}}",
  "version": "0.1.0",
  "description": "Generated TypeScript service ({{profile.displayName}}).",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "migrate": "prisma migrate deploy"
  },
  "dependencies": {
{{#each profile.dependencies}}
    "{{this.name}}": "{{this.version}}"{{#unless @last}},{{/unless}}
{{/each}}{{#if needsJwt}},
    "jsonwebtoken": "^9.0.3"
{{/if}}
  },
  "devDependencies": {
{{#each profile.devDependencies}}
    "{{this.name}}": "{{this.version}}"{{#unless @last}},{{/unless}}
{{/each}}{{#if needsJwt}},
    "@types/jsonwebtoken": "^9.0.10"
{{/if}}
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
