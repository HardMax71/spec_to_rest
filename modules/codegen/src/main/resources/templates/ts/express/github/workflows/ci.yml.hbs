name: CI

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

permissions:
  contents: read

jobs:
  test:
    runs-on: ubuntu-latest
{{#if db.hasDbService}}    services:
      db:
        image: {{db.dbImage}}
        env:
{{#each db.composeEnv}}          {{this.key}}: {{this.value}}
{{/each}}        ports:
          - "{{db.dbPort}}:{{db.dbPort}}"
        options: >-
          --health-cmd "{{db.dbHealthCmd}}" --health-interval 5s --health-timeout 3s --health-retries 10
{{/if}}    env:
      DATABASE_URL: {{db.appDsn}}
      BASE_URL: http://localhost:8080
    steps:
      - uses: actions/checkout@{{pins.checkout}}
        with:
          persist-credentials: false
      - uses: actions/setup-node@{{pins.setupNode}}
        with:
          node-version: "20"
      - run: npm install --no-audit --no-fund
      - run: npx prisma generate
      - run: npm run typecheck
      - run: npm test

  security:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@{{pins.checkout}}
        with:
          persist-credentials: false
      - uses: actions/setup-node@{{pins.setupNode}}
        with:
          node-version: "20"
      - name: Audit dependencies (npm audit)
        run: |
          npm install --package-lock-only --no-audit --no-fund
          npm audit --audit-level=high
      - uses: astral-sh/setup-uv@{{pins.setupUv}}
      - name: Audit workflow files (zizmor)
        run: uvx zizmor=={{pins.zizmor}} .github/workflows/
