[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{service.kebabName}}"
version = "0.1.0"
description = "Generated from {{service.name}}.spec"
requires-python = "{{profile.pythonVersion}}"
dependencies = [
{{#each profile.dependencies}}
    "{{this.name}}{{this.version}}",
{{/each}}
{{#if needsJwt}}
    "pyjwt>=2.10.1,<3",
{{/if}}
]

[project.optional-dependencies]
dev = [
{{#each profile.devDependencies}}
    "{{this.name}}{{this.version}}",
{{/each}}
    "schemathesis>=4.16,<5",
    "mutmut>=3.3,<4",
]

[tool.hatch.build.targets.wheel]
packages = ["app"]

[tool.ruff]
line-length = 100
target-version = "py310"

[tool.ruff.lint]
select = ["E", "F", "W", "I", "UP", "B"]
extend-ignore = ["B008"]
{{#if dafnyKernel}}

[tool.ruff.lint.per-file-ignores]
"app/dafny_kernel/**" = ["E", "F", "W", "I", "UP", "B"]
{{/if}}

[tool.mypy]
python_version = "3.10"
strict = true
{{#if dafnyKernel}}

# The Dafny-translated kernel is generated, untyped code: its own modules are
# exempt, and the boundary modules that call into it drop the untyped-call
# check (everything else in them stays strict).
[[tool.mypy.overrides]]
module = "app.dafny_kernel.*"
ignore_errors = true

[[tool.mypy.overrides]]
module = "app.services.*"
disallow_untyped_calls = false
{{/if}}

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
