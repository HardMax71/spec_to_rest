package models

{{#if entity.needsTime}}
import "time"
{{/if}}
{{#if entity.needsUuid}}
import "github.com/google/uuid"
{{/if}}
{{#if entity.needsDecimal}}
import "github.com/shopspring/decimal"
{{/if}}

type {{entity.entity.modelClassName}} struct {
{{#each entity.fields}}
	{{this.goField}} {{this.domainType}} `json:"{{this.jsonTag}}" db:"{{this.dbTag}}"`
{{/each}}
}

type {{entity.entity.createSchemaName}} struct {
{{#each entity.nonIdFields}}
	{{this.goField}} {{this.domainType}} `json:"{{this.jsonTag}}" validate:"required"`
{{/each}}
}

type {{entity.entity.readSchemaName}} struct {
{{#each entity.fields}}
	{{this.goField}} {{this.domainType}} `json:"{{this.jsonTag}}"`
{{/each}}
}

{{#each entity.customSchemas}}
type {{this.name}} struct {
{{#each this.fields}}
	{{this.goField}} {{this.domainType}} `json:"{{this.jsonTag}}" validate:"required"`
{{/each}}
}

{{/each}}
type ErrorResponse struct {
	Detail string `json:"detail"`
}
